# Application
APP_NAME=Aarogya360
DEBUG=false

# Database
DATABASE_URL=postgresql://postgres:admin123@localhost/Aarogya360

# Tests use a SEPARATE database (never run pytest against DATABASE_URL above)
TEST_DATABASE_URL=postgresql://postgres:admin123@localhost/Aarogya360_test

# JWT & Security
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
